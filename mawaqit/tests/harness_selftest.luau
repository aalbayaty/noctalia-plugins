--!nonstrict
local H = require("./harness")
H.installGlobals()
H.test("ui ctor returns node shape", function()
  local n = H.ui.column({ gap = 4 }, { H.ui.label({ text = "hi" }) })
  H.eq(n.type, "column", "type")
  H.eq(n.children[1].props.text, "hi", "child text")
end)
H.test("state watch fires", function()
  local seen
  H.state.watch("k", function(v) seen = v end)
  H.state.set("k", 7)
  H.eq(seen, 7, "watcher saw value")
end)
H.test("find walks tree", function()
  local tree = H.ui.row({}, { H.ui.glyph({ name = "moon" }) })
  local g = H.find(tree, function(nd) return nd.type == "glyph" end)
  H.eq(g.props.name, "moon", "found glyph")
end)
H.finish()
