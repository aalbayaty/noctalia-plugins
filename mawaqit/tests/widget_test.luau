--!nonstrict
local H = require("./harness")
H.setConfig({ textColor = "none", iconColor = "none", activeColor = "primary" })
local M = H.loadEntry("../widget")
local CD = { text = "Dhuhr 1h 5m", glyph = "sun-high", mode = "countdown", color = "primary" }
H.test("horizontal tree", function()
  local t = M.buildTree(CD, { textColor="none", iconColor="none", activeColor="primary" }, false)
  H.eq(t.type, "row", "row")
  local g = H.find(t, function(n) return n.type == "glyph" end)
  local l = H.find(t, function(n) return n.type == "label" end)
  H.eq(g.props.name, "sun-high", "glyph"); H.eq(l.props.text, "Dhuhr 1h 5m", "label")
end)
H.test("vertical tree is column", function()
  local t = M.buildTree(CD, { textColor="none", iconColor="none", activeColor="primary" }, true)
  H.eq(t.type, "column", "column")
end)
H.test("active mode uses activeColor", function()
  local t = M.buildTree({ text = "Now", glyph = "sun-high", mode = "now", color = "primary" },
                        { textColor="none", iconColor="none", activeColor="tertiary" }, false)
  local l = H.find(t, function(n) return n.type == "label" end)
  H.eq(l.props.color, "tertiary", "active color applied")
end)
H.test("start renders + watch re-renders + onClick opens panel", function()
  H.setConfig({ textColor="none", iconColor="none", activeColor="primary" })
  M._start()
  H.state.set("countdown", { text = "Fajr 10m", glyph = "sun-moon", mode = "countdown", color = "primary" })
  H.eq(H.calls.render.type, "row", "rendered a row")
  local l = H.find(H.calls.render, function(n) return n.type == "label" end)
  H.eq(l.props.text, "Fajr 10m", "re-render on watch")
  H.env.onClick()
  H.eq(H.calls.togglePanel, "aalbayaty/mawaqit:panel", "click opens panel")
end)
H.test("tooltip shows prayer time not countdown text", function()
  H.setConfig({ textColor="none", iconColor="none", activeColor="primary" })
  M._start()
  H.state.set("countdown", { text = "Fajr 10m 30s", label = "Fajr", next = "Fajr", time = "13:05",
    glyph = "sun-moon", mode = "countdown", color = "primary" })
  H.eq(H.calls.tooltip, "Fajr: 13:05", "tooltip shows prayer time, not countdown text")
end)
H.test("loading state renders … glyph", function()
  local t = M.buildTree({ text = "…", glyph = "building-mosque", mode = "loading", color = "primary" },
                        { textColor="none", iconColor="none", activeColor="primary" }, false)
  H.eq(t.type, "row", "renders row")
  local g = H.find(t, function(n) return n.type == "glyph" end)
  H.eq(g.props.name, "building-mosque", "loading glyph")
end)
H.test("elapsed mode uses activeColor", function()
  local t = M.buildTree({ text = "Done", glyph = "check", mode = "elapsed", color = "primary" },
                        { textColor="none", iconColor="none", activeColor="success" }, false)
  local l = H.find(t, function(n) return n.type == "label" end)
  H.eq(l.props.color, "success", "elapsed uses activeColor")
end)
H.test("error state renders", function()
  local t = M.buildTree({ text = "Error", glyph = "alert-circle", mode = "error", color = "primary" },
                        { textColor="error", iconColor="error", activeColor="primary" }, false)
  local l = H.find(t, function(n) return n.type == "label" end)
  H.eq(l.props.color, "error", "error text color")
end)
H.test("nodata mode renders", function()
  local t = M.buildTree({ text = "No data", glyph = "help-circle", mode = "nodata", color = "primary" },
                        { textColor="warning", iconColor="warning", activeColor="primary" }, false)
  local g = H.find(t, function(n) return n.type == "glyph" end)
  H.eq(g.props.color, "warning", "nodata icon color")
end)
H.finish()
