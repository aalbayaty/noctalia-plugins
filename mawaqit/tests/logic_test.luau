--!nonstrict
local H = require("./harness")
local M = H.loadEntry("../service")

H.test("formatTime 24h passthrough", function() H.eq(M.formatTime("13:05", false), "13:05", "24h") end)
H.test("formatTime 12h pm", function() H.eq(M.formatTime("13:05", true), "1:05 PM", "pm") end)
H.test("formatTime 12h am + midnight", function()
  H.eq(M.formatTime("00:07", true), "12:07 AM", "midnight")
  H.eq(M.formatTime("12:00", true), "12:00 PM", "noon")
end)
H.test("toArabicNumerals", function() H.eq(M.toArabicNumerals("1447"), "١٤٤٧", "digits") end)
H.test("formatCountdownText", function()
  H.eq(M.formatCountdownText(3725), "1h 2m 5s", "h m s")
  H.eq(M.formatCountdownText(125), "2m 5s", "m s")
  H.eq(M.formatCountdownText(9), "9s", "s")
end)
H.test("cleanTime strips tz", function() H.eq(M.cleanTime("05:12 (BST)"), "05:12", "strip") end)
H.test("buildTuneParam off", function()
  H.eq(M.buildTuneParam({ tune = false }), "0,0,0,0,0,0,0,0,0", "zero")
end)
H.test("buildTuneParam on", function()
  H.eq(M.buildTuneParam({ tune = true, tuneFajr = 2, tuneDhuhr = -1, tuneAsr = 0, tuneMaghrib = 3, tuneIsha = 0 }),
       "0,2,0,-1,0,3,0,0,0", "order Imsak,Fajr,Sunrise,Dhuhr,Asr,Maghrib,Sunset,Isha,Midnight")
end)
H.test("buildWeeklyUrl", function()
  local u = M.buildWeeklyUrl({ city = "London", country = "UK", method = "3", school = "0", tune = false }, "16-07-2026")
  H.ok(u:find("timingsByCity/16%-07%-2026", 1), "date path")
  H.ok(u:find("city=London") ~= nil, "city")
  H.ok(u:find("country=UK") ~= nil, "country")
  H.ok(u:find("method=3") ~= nil, "method")
  H.ok(u:find("methodSettings=null,null,null") ~= nil, "methodSettings")
  H.ok(u:find("school=0") ~= nil, "school")
  H.ok(u:find("days=7") ~= nil, "days")
end)
H.test("buildWeeklyUrl custom angles", function()
  local u = M.buildWeeklyUrl({ city = "X", country = "Y", method = "99", school = "0", fajrAngle = "18", ishaAngle = "17", tune = false }, "16-07-2026")
  H.ok(u:find("methodSettings=18,null,17") ~= nil, "angles")
end)
local WEEKLY = { code = 200, data = {
  { date = { gregorian = { date = "16-07-2026" }, readable = "16 Jul 2026",
             hijri = { day = "01", month = { number = 1, en = "Muharram", ar = "محرم", days = 30 }, year = "1448" } },
    timings = { Imsak = "02:40 (BST)", Fajr = "02:50", Sunrise = "05:03", Dhuhr = "13:05",
                Asr = "17:20", Maghrib = "21:07", Isha = "23:10" } },
  { date = { gregorian = { date = "17-07-2026" }, readable = "17 Jul 2026",
             hijri = { day = "02", month = { number = 1, en = "Muharram", ar = "محرم", days = 30 }, year = "1448" } },
    timings = { Fajr = "02:52", Dhuhr = "13:05", Asr = "17:19", Maghrib = "21:06", Isha = "23:08", Imsak = "02:42", Sunrise = "05:04" } },
} }
H.test("normalizeWeekly picks today", function()
  local e = M.normalizeWeekly(WEEKLY, "2026-07-16")
  H.eq(e.timings.Fajr, "02:50", "fajr today")
  H.eq(e.timings.Imsak, "02:40", "imsak cleaned of tz")
  H.eq(e.gregorian, "16-07-2026", "greg")
  H.eq(e.readable, "16 Jul 2026", "readable")
  H.eq(tonumber(e.hijri.day), 1, "hijri day")
end)
H.test("normalizeWeekly fallback data[0]", function()
  local e = M.normalizeWeekly(WEEKLY, "2030-01-01")
  H.eq(e.gregorian, "16-07-2026", "fallback first")
end)
H.test("normalizeSingleDay", function()
  local e = M.normalizeSingleDay({ code = 200, data = {
    timings = { Fajr = "03:00 (UTC)", Dhuhr = "13:00", Asr = "17:00", Maghrib = "21:00", Isha = "23:00", Imsak = "02:50", Sunrise = "05:00" },
    date = { gregorian = { date = "16-07-2026" }, readable = "16 Jul 2026",
             hijri = { day = "01", month = { number = 1, en = "Muharram", ar = "محرم", days = 30 }, year = "1448" } } } })
  H.eq(e.timings.Fajr, "03:00", "cleaned")
  H.eq(e.gregorian, "16-07-2026", "greg")
end)
local function secs(hhmm) local h,m = hhmm:match("(%d+):(%d+)"); return tonumber(h)*3600 + tonumber(m)*60 end
local T = { Imsak="02:40", Fajr="02:50", Sunrise="05:03", Dhuhr="13:05", Asr="17:20", Maghrib="21:07", Isha="23:10" }
local baseCfg = { showCountdown = true, showElapsed = false, hidePrayerName = false, use12hourFormat = false,
                  dynamicIcon = false, widgetIcon = "building-mosque", textColor = "none", iconColor = "none", activeColor = "primary" }
H.test("countdown normal picks next", function()
  local c = M.computeCountdown(T, secs("12:00"), baseCfg, { isRamadan = false, isJumuah = false })
  H.eq(c.next, "Dhuhr", "next is Dhuhr")
  H.eq(c.mode, "countdown", "mode")
  H.eq(c.secondsToNext, secs("13:05") - secs("12:00"), "delta")
  H.ok(c.text:find("Dhuhr") ~= nil, "label in text")
end)
H.test("countdown now grace", function()
  local c = M.computeCountdown(T, secs("13:07"), baseCfg, { isRamadan = false, isJumuah = false })
  H.eq(c.mode, "now", "within 5 min of Dhuhr")
  H.eq(c.secondsToNext, 0, "zero")
end)
H.test("countdown elapsed", function()
  local cfg = table.clone(baseCfg); cfg.showElapsed = true
  local c = M.computeCountdown(T, secs("13:20"), cfg, { isRamadan = false, isJumuah = false })
  H.eq(c.mode, "elapsed", "13 min after Dhuhr")
  H.eq(c.elapsed, true, "elapsed flag")
end)
H.test("countdown Jumuah label", function()
  local c = M.computeCountdown(T, secs("12:00"), baseCfg, { isRamadan = false, isJumuah = true })
  H.ok(c.text:find("Jumu") ~= nil, "Dhuhr shows as Jumu'ah")
end)
H.test("prayer rows next flag + order", function()
  local rows = M.buildPrayerRows(T, baseCfg, { isRamadan = false, isJumuah = false }, "Dhuhr")
  H.eq(rows[1].key, "Imsak", "order start")
  local dhuhr for _, r in ipairs(rows) do if r.key == "Dhuhr" then dhuhr = r end end
  H.eq(dhuhr.isNext, true, "dhuhr is next")
  H.eq(dhuhr.highlight, "next", "highlight next")
end)
H.test("prayer rows ramadan imsak/maghrib highlight", function()
  local rows = M.buildPrayerRows(T, baseCfg, { isRamadan = true, isJumuah = false }, "Fajr")
  local im, mg for _, r in ipairs(rows) do if r.key=="Imsak" then im=r elseif r.key=="Maghrib" then mg=r end end
  H.eq(im.highlight, "imsak", "imsak highlight in ramadan")
  H.eq(mg.highlight, "maghrib", "maghrib highlight in ramadan")
end)

H.test("toJDN known", function() H.eq(M.toJDN(2026, 7, 16), 2461238, "16 Jul 2026") end)
H.test("jdnToGreg roundtrip", function()
  local y, m, d = M.jdnToGreg(2461238); H.eq(y, 2026, "y"); H.eq(m, 7, "m"); H.eq(d, 16, "d")
end)
H.test("parseReadableToJDN", function() H.eq(M.parseReadableToJDN("16 Jul 2026"), 2461238, "parse") end)
H.test("weekdayColumn ws=1", function() H.eq(M.weekdayColumn(2461238, 1), 3, "Thu col with Monday start") end)
H.test("weekdayColumn ws=0", function() H.eq(M.weekdayColumn(2461238, 0), 4, "Sunday start") end)
H.test("hijri leap", function() H.eq(M.isHijriLeapYear(1448), (function() local r=false for _,v in ipairs({2,5,7,10,13,16,18,21,24,26,29}) do if v == 1448 % 30 then r=true end end return r end)(), "leap table") end)
H.test("estimateMonthLength parity", function()
  H.eq(M.estimateMonthLength(1, 1448), 30, "odd month 30")
  H.eq(M.estimateMonthLength(2, 1448), 29, "even month 29")
end)

H.test("eventsFor Ashura", function() local e = M.eventsFor(1, 10); H.truthy(e, "ashura"); H.ok(e.en:find("Ashura") ~= nil, "en") end)
H.test("eventsFor Qadr night 27", function() local e = M.eventsFor(9, 27); H.truthy(e, "qadr"); H.ok(e.ar ~= "", "ar") end)
H.test("eventsFor Ayyam al-Bid", function()
  H.truthy(M.eventsFor(2, 13), "13"); H.truthy(M.eventsFor(2, 14), "14"); H.truthy(M.eventsFor(2, 15), "15")
  H.ok(M.eventsFor(9, 13) == nil, "not in ramadan")
end)
H.test("isLastTenNights", function()
  H.eq(M.isLastTenNights(9, 21, 30), true, "ramadan day 21")
  H.eq(M.isLastTenNights(9, 19, 30), false, "day 19")
  H.eq(M.isLastTenNights(1, 25, 30), false, "not ramadan")
end)
H.test("hadithForDay deterministic + shaped", function()
  local a = M.hadithForDay(1); H.truthy(a.text, "text"); H.truthy(a.source, "source")
  H.eq(M.hadithForDay(1).text, a.text, "same day same hadith")
end)

H.finish()
